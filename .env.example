# API: copy to .env for local development. Never commit the copy.
APP_ENV=development
APP_TIMEZONE=America/Toronto
DATABASE_URL=sqlite:///./levels-dev.db
TURSO_AUTH_TOKEN=
ADMIN_USERNAME=brandan
ADMIN_PASSWORD_HASH=<generate-with-hash-password-command>
JWT_SECRET_KEY=<replace-with-a-random-secret>
CORS_ALLOWED_ORIGINS=http://localhost:5173
PUBLIC_WEB_ORIGIN=http://localhost:5173
LOG_LEVEL=INFO
REGISTRATION_ENABLED=true

# Web: Vite exposes only VITE_ variables. These values are public configuration.
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_BASE_PATH=/
